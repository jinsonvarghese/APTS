{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["requirements"],
  "properties": {
    "version": { "type": "string" },
    "source": { "type": "string" },
    "last_updated": { "type": "string" },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "domain",
          "tier",
          "level",
          "title"
        ],
        "properties": {
          "id": { "type": "string" },
          "domain": { "type": "string" },
          "tier": { "type": "integer" },
          "level": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "verification": { "type": "string" }
        }
      }
    }
  }
}
